# Example Environment Variables
# Copy this file to .env.development or .env.production and fill in your values

# Application
VITE_APP_NAME=Workflow Studio
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# API Configuration
VITE_API_BASE_URL=http://localhost:8080/api
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3

# Feature Flags
VITE_ENABLE_ASSISTANT_PANEL=true
VITE_ENABLE_WORKFLOW_EDITOR=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_MODE=true

# Mock Data
VITE_USE_MOCK_DATA=true

# Third-party Services
VITE_ANALYTICS_KEY=your_analytics_key_here
VITE_SENTRY_DSN=your_sentry_dsn_here

# Performance
VITE_ENABLE_SOURCE_MAPS=true
