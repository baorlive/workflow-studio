{
  "name": "workflow-studio-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Workflow Studio Interactive Application - Refactored with Vite",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest --config vitest.config.js",
    "test:ui": "vitest --ui --config vitest.config.js",
    "test:coverage": "vitest run --coverage --config vitest.config.js",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0 -c .eslintrc.cjs --no-eslintrc",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css,md}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.0.0",
    "lodash": "^4.17.23",
    "lucide-react": "^0.294.0",
    "marked": "^11.0.0",
    "react": "^18.2.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.2.0",
    "react-json-view": "^1.21.3",
    "reactflow": "^11.11.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-markdown": "^5.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^23.0.1",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.3.6",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.46.0",
    "vite": "^5.0.8",
    "vitest": "^1.1.0"
  }
}
